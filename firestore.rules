rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function profile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isLegacyAdmin() {
      return signedIn()
        && !('role' in profile())
        && profile().createdAt <= timestamp.value('2026-07-22T08:05:00Z');
    }

    function isConfiguredAdmin() {
      return signedIn()
        && 'email' in request.auth.token
        && request.auth.token.email in [
          'seoulddddd@gmail.com',
          'gaingnarim@gmail.com',
          'nm22491@gmail.com',
          'jeungseunga0@gmail.com'
        ];
    }

    function isAdmin() {
      return signedIn() && (
        isConfiguredAdmin()
        || ('admin' in request.auth.token && request.auth.token.admin == true)
        || ('role' in profile() && profile().role == 'admin')
        || isLegacyAdmin()
      );
    }

    function isEditor() {
      return isAdmin() || (
        signedIn() && 'role' in profile() && profile().role == 'editor'
      );
    }

    function itemWasSaved(itemType, itemId) {
      return signedIn() && (
        (itemType == 'post'
          && exists(/databases/$(database)/documents/users/$(request.auth.uid)/bookmarks/$(itemId)))
        || (itemType == 'course'
          && exists(/databases/$(database)/documents/users/$(request.auth.uid)/savedCourses/$(itemId)))
      );
    }

    function itemWasCounted(itemType, itemId) {
      return signedIn() && (
        (itemType == 'post'
          && exists(/databases/$(database)/documents/users/$(request.auth.uid)/bookmarks/$(itemId))
          && get(/databases/$(database)/documents/users/$(request.auth.uid)/bookmarks/$(itemId)).data.counted == true)
        || (itemType == 'course'
          && exists(/databases/$(database)/documents/users/$(request.auth.uid)/savedCourses/$(itemId))
          && get(/databases/$(database)/documents/users/$(request.auth.uid)/savedCourses/$(itemId)).data.counted == true)
      );
    }

    function itemIsCountedAfter(itemType, itemId) {
      return signedIn() && (
        (itemType == 'post'
          && existsAfter(/databases/$(database)/documents/users/$(request.auth.uid)/bookmarks/$(itemId))
          && getAfter(/databases/$(database)/documents/users/$(request.auth.uid)/bookmarks/$(itemId)).data.counted == true)
        || (itemType == 'course'
          && existsAfter(/databases/$(database)/documents/users/$(request.auth.uid)/savedCourses/$(itemId))
          && getAfter(/databases/$(database)/documents/users/$(request.auth.uid)/savedCourses/$(itemId)).data.counted == true)
      );
    }

    function validBookmarkCount() {
      return request.resource.data.keys().hasOnly([
          'itemId', 'itemType', 'count', 'updatedAt'
        ])
        && request.resource.data.itemId is string
        && request.resource.data.itemType in ['post', 'course']
        && request.resource.data.count is int
        && request.resource.data.count >= 0;
    }

    function isValidMemberPost() {
      return signedIn()
        && request.resource.data.keys().hasOnly([
          'id', 'ownerId', 'name', 'region', 'address', 'menu', 'hours', 'phone', 'caption',
          'tags', 'images', 'author', 'handle', 'avatar', 'rating', 'likes',
          'comments', 'published', 'createdAt'
        ])
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.region == '전라남도 구례군'
        && request.resource.data.address is string
        && request.resource.data.address.matches('.*구례군.*')
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.menu is string
        && request.resource.data.hours is string
        && request.resource.data.phone is string
        && request.resource.data.caption is string
        && request.resource.data.tags is list
        && request.resource.data.images is list
        && request.resource.data.images.size() > 0
        && request.resource.data.images.size() <= 8
        && request.resource.data.rating == 0
        && request.resource.data.likes == 0
        && request.resource.data.comments == 0
        && request.resource.data.published == true;
    }

    match /posts/{postId} {
      allow read: if true;
      allow create: if isEditor() || isValidMemberPost();
      allow update, delete: if isEditor();
    }

    match /courses/{courseId} {
      allow read: if true;
      allow write: if isEditor();
    }

    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.role == 'member';
      allow update: if isAdmin() || (
        signedIn()
        && request.auth.uid == userId
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['displayName', 'email', 'updatedAt', 'lastLoginAt'])
      );
      allow delete: if isAdmin() && request.auth.uid != userId;

      match /bookmarks/{postId} {
        allow read: if signedIn() && request.auth.uid == userId;
        allow create: if signedIn()
          && request.auth.uid == userId
          && request.resource.data.keys().hasOnly(['postId', 'counted', 'savedAt'])
          && request.resource.data.counted == true;
        allow update: if false;
        allow delete: if signedIn() && request.auth.uid == userId;
      }

      match /savedCourses/{courseId} {
        allow read: if signedIn() && request.auth.uid == userId;
        allow create: if signedIn()
          && request.auth.uid == userId
          && request.resource.data.keys().hasOnly(['courseId', 'counted', 'savedAt'])
          && request.resource.data.counted == true;
        allow update: if false;
        allow delete: if signedIn() && request.auth.uid == userId;
      }
    }

    match /bookmarkCounts/{countId} {
      allow read: if true;
      allow create: if validBookmarkCount()
        && request.resource.data.count == 1
        && !itemWasSaved(request.resource.data.itemType, request.resource.data.itemId)
        && itemIsCountedAfter(request.resource.data.itemType, request.resource.data.itemId);
      allow update: if validBookmarkCount()
        && request.resource.data.itemId == resource.data.itemId
        && request.resource.data.itemType == resource.data.itemType
        && (
          (request.resource.data.count == resource.data.count + 1
            && !itemWasSaved(resource.data.itemType, resource.data.itemId)
            && itemIsCountedAfter(resource.data.itemType, resource.data.itemId))
          || (resource.data.count > 0
            && request.resource.data.count == resource.data.count - 1
            && itemWasCounted(resource.data.itemType, resource.data.itemId)
            && !itemIsCountedAfter(resource.data.itemType, resource.data.itemId))
        );
      allow delete: if false;
    }

    match /publicProfiles/{userId} {
      allow read: if true;
      allow create, update: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.keys().hasOnly([
          'displayName', 'handle', 'avatar', 'updatedAt'
        ])
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() > 0
        && request.resource.data.displayName.size() <= 30
        && request.resource.data.handle is string
        && request.resource.data.avatar is string
        && request.resource.data.avatar.size() <= 200000;
      allow delete: if signedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /restaurant_submissions/{submissionId} {
      allow create: if signedIn()
        && request.resource.data.user_id == request.auth.uid;
      allow read, update, delete: if isEditor();
    }

    match /feedComments/{feedId}/comments/{commentId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 500;
      allow update: if false;
      allow delete: if signedIn()
        && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /appMeta/{documentId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
